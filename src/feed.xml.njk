---
permalink: "feed.xml"
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ metadata.title }}</title>
    <link>{{ metadata.siteUrl }}</link>
    <description>Personal blog by {{ metadata.author }} — covering software engineering, startup building, and learning in public.</description>
    <language>en</language>
    <atom:link href="{{ metadata.siteUrl }}/feed.xml" rel="self" type="application/rss+xml"/>
    {%- for post in collections.post | reverse %}
    <item>
      <title>{{ post.data.title }}</title>
      <link>{{ metadata.siteUrl }}{{ post.url }}</link>
      <guid isPermaLink="true">{{ metadata.siteUrl }}{{ post.url }}</guid>
      <description>{{ post.data.description }}</description>
      <pubDate>{{ post.date.toUTCString() }}</pubDate>
      <author>{{ metadata.author }}</author>
    </item>
    {%- endfor %}
  </channel>
</rss>
